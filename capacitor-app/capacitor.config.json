{
  "appId": "io.mqlc.admin",
  "appName": "MQLC Admin",
  "webDir": "www",
  "server": {
    "url": "https://mqlc.vercel.app/admin.html",
    "cleartext": false,
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0
    },
    "StatusBar": {
      "overlaysWebView": false,
      "backgroundColor": "#1A1A2E",
      "style": "DARK"
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK"
    }
  }
}